{
  "name": "sohojatra",
  "private": true,
  "type": "module",
  "version": "0.2.0",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "validate:config": "node scripts/validate-config.mjs",
    "validate:config:offline": "node scripts/validate-config.mjs --offline",
    "prestart": "node scripts/validate-config.mjs",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix",
    "secrets:scan": "secretlint \"**/*\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:security": "vitest run tests/security",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --max-warnings=0",
      "secretlint"
    ],
    "*.{json,md,yml,yaml,env,sh}": [
      "secretlint"
    ]
  },
  "dependencies": {
    "@sentry/nextjs": "10.59.0",
    "@serwist/turbopack": "9.5.11",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.2",
    "@types/lodash": "4.17.24",
    "@types/qrcode": "1.5.6",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.38.0",
    "@vercel/analytics": "2.0.1",
    "@vercel/speed-insights": "2.0.0",
    "ably": "1.2.50",
    "esbuild": "0.28.1",
    "esbuild-wasm": "0.28.1",
    "eslint-config-next": "16.2.9",
    "leaflet": "1.9.4",
    "lodash": "4.18.1",
    "lucide-react": "1.21.0",
    "next": "16.2.9",
    "otpauth": "9.5.1",
    "qrcode": "1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hot-toast": "2.6.0",
    "react-leaflet": "5.0.0",
    "serwist": "9.5.11",
    "tweetnacl": "1.0.3",
    "tweetnacl-util": "0.15.1",
    "uuid": "9.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.12.0",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
    "@types/leaflet": "1.9.21",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/uuid": "9.0.8",
    "@vitejs/plugin-react": "4.3.2",
    "@vitest/coverage-v8": "4.1.9",
    "autoprefixer": "10.5.0",
    "eslint": "9.12.0",
    "eslint-plugin-react-hooks": "5.1.0-rc-fb9a90fa48-20240614",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "15.11.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "postcss": "8.5.15",
    "secretlint": "13.0.2",
    "tailwindcss": "3.4.13",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.1",
    "vite": "5.4.8",
    "vite-plugin-pwa": "1.3.0",
    "vite-tsconfig-paths": "6.1.1",
