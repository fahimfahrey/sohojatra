# Public (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Shared secret used to derive the real-time payload encryption key
# (PBKDF2-HMAC-SHA-256 → nacl.secretbox). Rotate to invalidate prior payloads.
NEXT_PUBLIC_REALTIME_ENCRYPTION_SECRET=

# Server-only — never expose to the client
ABLY_API_KEY=

# Upstash Redis for rate limiting (https://console.upstash.com/redis)
# Falls back to in-memory rate limiting when these are unset (single-process only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry error tracking (https://sentry.io)
# Required at runtime to ship events; leave blank in local dev to disable.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Build-time upload of source maps (CI only). Leave unset locally.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Optional tuning
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Set to "true" to skip source-map upload during a build that has SENTRY_AUTH_TOKEN set.
SENTRY_DISABLE_BUILD=

# Connection pooling (PgBouncer)
# Enable via: Supabase Dashboard → Settings → Database → Connection Pooling (Transaction mode)
# Use the port-6543 pooler URL for any direct Postgres workloads (Prisma, pg, migrations).
# The Supabase JS client (PostgREST) manages its own pool — no change needed there.
# SUPABASE_DB_POOLER_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
